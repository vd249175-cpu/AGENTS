  "managementDiscoveryScanMessageLimit": null,
  "documentQueryTraceLimit": 16,
  "documentWriteTraceLimit": 16,
  "graphQueryTraceLimit": 16,
  "graphWriteTraceLimit": 16,
  "graphQueryKeywordTopK": 6,
  "graphQueryKeywordTopKLimit": 10,
  "graphQueryDistanceTopK": 6,
  "graphQueryDistanceTopKLimit": 10,
  "graphQueryDistanceMaxDistance": 1.5,
  "graphQueryUsefulMaxItems": 12,
  "graphQueryUsefulMaxTotalChars": 3000,
  "graphQueryBlockedMaxItems": 12,
  "graphQueryBlockedMaxTotalChars": 3000,
  "agentStepTraceEventType": "agent_step_timing",
  "agentStepTraceEmitFullState": true,
  "debugTraceEventType": "agent_debug_trace",
