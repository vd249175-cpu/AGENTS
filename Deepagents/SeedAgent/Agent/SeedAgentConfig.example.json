{
  "agentName": "SeedAgent",
  "agentRole": "knowledge seed agent",
  "agentDescription": "负责把 knowledge 中的长文档切分进入记忆图，并通过记忆管理工具维护知识库。",
  "agentResponsibilities": [
    "组织当前会话的任务步骤",
    "通过 MainServer 与其他 Agent 通讯",
    "将 workspace/knowledge 中的长文档切分并写入记忆",
    "使用 manage_knowledge 查询、整理、修正和关联记忆图内容",
    "以流式事件汇报关键执行过程",
    "使用 middleware 自动挂载的工具，不在 agent 装配层重复挂 tools"
  ],
  "systemPromptExtra": "",
  "chatModelProvider": "openai",
  "chatModel": "gpt-5-nano",
  "chatBaseUrl": "",
  "chatApiKey": "",
  "chatTemperature": 0.0,
  "ollamaBaseUrl": "http://127.0.0.1:11434",
  "embeddingProvider": "openai",
  "embeddingModel": "text-embedding-3-small",
  "embeddingBaseUrl": "",
  "embeddingApiKey": "",
  "embeddingDimensions": 1536,
  "neo4jUri": "neo4j://localhost:7687",
  "neo4jUsername": "neo4j",
  "neo4jPassword": "",
  "neo4jDatabase": null,
  "enableMemoryMiddleware": true,
  "enableSkillsMiddleware": true,
  "enableKnowledgeManagerMiddleware": true,
  "enableKnowledgeIngestMiddleware": true,
  "enableReceiveMessagesMiddleware": true,
  "enableSendMessagesMiddleware": true,
  "enableAgentStepTraceMiddleware": true,
  "enableDebugTraceMiddleware": false,
  "defaultRunId": "seedagent-run",
  "defaultThreadId": "default",
  "defaultDestination": null,
  "defaultMessageType": "message",
  "hideToolMessageContent": false,
  "blockSelfTarget": true,
  "maxInboxItems": 20,
  "peekPeersInGuidance": true,
  "resume": true,
  "chunkApplyDeriveDocumentRunId": false,
  "chunkApplyCheckpointPath": null,
  "chunkApplyCachePath": null,
  "chunkApplyStagingPath": null,
  "chunkApplyRecursionLimit": null,
  "shardCount": 4,
  "maxWorkers": 2,
  "referenceBytes": 6000,
  "chunkApplyMaxRetries": 3,
  "chunkHistoryLineCount": 4,
  "chunkActiveLineCount": 8,
  "chunkPreviewLineCount": 4,
  "chunkLineWrapWidth": 30,
  "chunkWindowBackBytes": 1200,
  "chunkWindowForwardBytes": 2400,
  "chunkTraceLimit": 16,
  "chunkMaxRetries": 3,
  "documentEdgeDistance": 0.3,
  "persistKeywordEmbeddings": true,
  "knowledgeRunId": "SeedAgent-knowledge",
  "knowledgeTraceLimit": 16,
  "knowledgeManagerSystemPrompt": null,
  "knowledgeManagerTemperature": 0.0,
  "knowledgeManagerDebug": false,
  "streamInnerKnowledgeAgent": true,
